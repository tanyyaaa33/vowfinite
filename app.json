{
  "expo": {
    "name": "VowFinity",
    "slug": "vowfinity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5F9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vowfinity.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF5F9",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.vowfinity.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B9D",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "VowFinity needs access to your photos to set your couple avatar."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "VowFinity needs microphone access so you can record voice bombs for your partner."
        }
      ],
      "expo-asset"
    ]
  }
}
